{
  "name": "fit-rapido-monorepo",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build:api",
    "build:admin": "cd admin && npm install && npm run build",
    "build:api": "cd api && npm install && npm run build",
    "start": "cd api && npm run start:prod",
    "install:admin": "cd admin && npm install",
    "install:api": "cd api && npm install"
  },
  "dependencies": {
    "next": "latest",
    "typescript": "latest"
  }
}
